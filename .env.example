# Copy to .env (gitignored) and fill in. Values intentionally blank.
# All of these are read ONLY via backend/utils/config.py.

# --- Runtime ---
# ENV=prod fails fast at startup if any credential below is blank; ENV=dev only
# warns, so this all-blank file boots in dev but never in prod.
ENV=dev
# Comma-separated allowed CORS origins, e.g. in prod:
#   https://docchat.pages.dev,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# --- Models (DEMO MODE defaults — override to migrate; never edit agent code) ---
# These serve users who haven't brought their own key (BYOK). BYOK requests
# carry X-LLM-*/X-Embed-* headers and never touch these. Gemini models served
# via OpenRouter (one gateway); Groq is the demo failover.
REWRITER_MODEL=openrouter/google/gemini-3.1-flash-lite-preview
ANSWERER_MODEL=openrouter/google/gemini-3-flash-preview
EMBED_MODEL=openrouter/google/gemini-embedding-001

# --- Provider credentials (demo mode only; BYOK keys arrive per-request) ---
OPENROUTER_API_KEY=   # demo gateway — LLM + embedding calls without BYOK
GROQ_API_KEY=         # demo failover provider

# --- Auth ---
# Signs every session JWT. Generate a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required when ENV=prod. Rotating it logs everyone out (all tokens invalidate).
JWT_SECRET=
JWT_TTL_DAYS=7

# --- Data stores ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=docchat_chunks
UPSTASH_URL=
UPSTASH_TOKEN=

# --- Tunables ---
MAX_CONCURRENT_LLM_CALLS=8
MAX_DOC_MB=10
MAX_PAGES=100
MAX_DOCS_PER_SESSION=3
MAX_QUESTIONS_PER_DAY=25
MAX_UPLOADS_PER_IP_DAY=10
RELEVANCE_THRESHOLD=0.30
CHUNK_TOKENS=450
CHUNK_OVERLAP=80
SESSION_TTL_HOURS=24
EMBED_BATCH_SIZE=100

# --- Retrieval quality (v3) ---
# RRF over-fetches RETRIEVAL_POOL candidates; FlashRank (open-source ONNX
# cross-encoder, ~4MB, CPU) reranks them down to RERANK_TOP_K for the answerer.
# RERANK_ENABLED=false degrades to plain RRF order.
RERANK_ENABLED=true
RERANK_TOP_K=6
RETRIEVAL_POOL=12
