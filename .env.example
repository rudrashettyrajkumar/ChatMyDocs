# Copy to .env (gitignored) and fill in. Values intentionally blank.
# All of these are read ONLY via backend/utils/config.py.

# --- Runtime ---
# ENV=prod fails fast at startup if any credential below is blank; ENV=dev only
# warns, so this all-blank file boots in dev but never in prod.
ENV=dev
FRONTEND_ORIGIN=http://localhost:5173

# --- Models (override to migrate; never edit agent code) ---
# Gemini models served via OpenRouter (one gateway); Groq is the failover.
REWRITER_MODEL=openrouter/google/gemini-3.1-flash-lite-preview
ANSWERER_MODEL=openrouter/google/gemini-3-flash-preview
EMBED_MODEL=openrouter/google/gemini-embedding-001

# --- Provider credentials ---
OPENROUTER_API_KEY=   # primary gateway — every LLM + embedding call
GROQ_API_KEY=         # failover provider

# --- Auth ---
# Signs every session JWT. Generate a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required when ENV=prod. Rotating it logs everyone out (all tokens invalidate).
JWT_SECRET=
JWT_TTL_DAYS=7

# --- Data stores ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=docchat_chunks
UPSTASH_URL=
UPSTASH_TOKEN=

# --- Tunables ---
MAX_CONCURRENT_LLM_CALLS=8
MAX_DOC_MB=10
MAX_PAGES=100
MAX_DOCS_PER_SESSION=3
MAX_QUESTIONS_PER_DAY=25
MAX_UPLOADS_PER_IP_DAY=10
RELEVANCE_THRESHOLD=0.30
CHUNK_TOKENS=450
CHUNK_OVERLAP=80
SESSION_TTL_HOURS=24
EMBED_BATCH_SIZE=100
